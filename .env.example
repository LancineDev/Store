# Environment variables example for production
# Copy to .env and fill values before deploying

# App & auth
NEXTAUTH_URL=https://your-domain.com
NEXTAUTH_SECRET=replace_with_secure_random_value
AUTH_SECRET=replace_with_secure_random_value
ADMIN_EMAIL=admin@example.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Payment (CinetPay)
CINETPAY_API_KEY=your_cinetpay_api_key
CINETPAY_SITE_ID=your_cinetpay_site_id

# Optional: Redis for rate limiting / session store
REDIS_URL=redis://:password@redis-host:6379

# Other
SENTRY_DSN=
# Obligatoire — sans AUTH_SECRET, Auth.js renvoie une erreur de configuration (/api/auth/error).
# Générez une clé, ex. : openssl rand -base64 32
AUTH_SECRET=

# URL publique du site (production)
AUTH_URL=http://localhost:3000

# Comptes administrateurs : e-mails séparés par des virgules (connexion e-mail ou Google)
ADMIN_EMAIL=admin@votredomaine.com

# Database example (Postgres)
DATABASE_URL=postgresql://user:password@db-host:5432/sportzone

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Créez des identifiants OAuth client (application Web), URI autorisés :
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Alias pris en charge par NextAuth (optionnel, à la place de AUTH_GOOGLE_*)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Set when deploying to production
NODE_ENV=production
