# Obligatoire — sans AUTH_SECRET, Auth.js renvoie une erreur de configuration (/api/auth/error).
# Générez une clé, ex. : openssl rand -base64 32
AUTH_SECRET=

# URL publique du site (production)
AUTH_URL=http://localhost:3000

# Comptes administrateurs : e-mails séparés par des virgules (connexion e-mail ou Google)
ADMIN_EMAIL=admin@votredomaine.com

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Créez des identifiants OAuth client (application Web), URI autorisés :
#   http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Alias pris en charge par NextAuth (optionnel, à la place de AUTH_GOOGLE_*)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
